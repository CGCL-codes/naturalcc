# Figma2Code Environment Configuration
# Copy this file to .env and fill in your values

# =============================================================================
# API Keys (Required for running experiments)
# =============================================================================

# OpenRouter API key for accessing LLM models
# Get your key at: https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-your-api-key-here

# =============================================================================
# Proxy Settings (Optional)
# =============================================================================

# HTTP/HTTPS proxy for API requests (leave empty if not needed)
HTTP_PROXY=
HTTPS_PROXY=

# =============================================================================
# Figma Credentials (Optional - for data collection only)
# =============================================================================

# Figma API key for accessing Figma API
# Get your key at: https://www.figma.com/developers/api
FIGMA_API_KEY=

# Figma account credentials for crawling community pages
# Only needed if you want to collect new data from Figma
FIGMA_EMAIL=
FIGMA_PASSWORD=

# =============================================================================
# Image Hosting (Optional - defaults provided)
# =============================================================================

# URL prefix for hosted reference images
# Default: https://raw.githubusercontent.com/gystar/img_hub/main/figma/
IMAGE_HOST_PREFIX=

# URL prefix for smaller/compressed reference images (for Claude compatibility)
# Default: https://raw.githubusercontent.com/gystar/img_hub/main/figma_small/
IMAGE_HOST_PREFIX_SMALL=
